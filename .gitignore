# Secrets / env
.env
.env.*
!.env.example

# Generated prompt files — distributed via the data tarball
# on GitHub releases, not via git
generated/

# The data tarball itself — produced at repo root by
# scripts/build_data_tarball.sh. Published as a GitHub release artifact.
# Pattern matches both lcvb-data-*.tar.gz (legacy) and usvb-data-*.tar.gz,
# plus any split-part files (.tar.gz.part00, .part01, ...).
*vb-data-*.tar.gz
*vb-data-*.tar.gz.part*

# Tarball-build INTEGRITY manifests — generated at repo root just before
# being added to a release tarball. Never tracked.
INTEGRITY.json
ABLATION_INTEGRITY.json
*_INTEGRITY.json

# Run outputs — results + checkpoints, distributed via the data tarball
data/runs/
pipeline/api_logs/

# Archives of all kinds (recovery traces, pre-canon-rename data,
# stage-specific snapshots, etc.) — never tracked
data/archive_*/
data/runs_*INVALID*/
data/runs_*SCRUBBED*/
data/runs_pilot/
archive_*/

# Per-run batch-API manifests (provider batch_ids — ephemeral)
batch_manifests/
analysis_*/batch_manifests/

# Sibling-analysis bulk data — judged TSVs + smoke runs in any analysis_*/
# directory (analysis_ablation, analysis_judge_swap, ...). Same convention
# as data/runs/: scripts + small derived CSV/TXT artifacts are tracked,
# raw TSVs are distributed via the release tarball (usvb-data-ablation-*.tar.gz).
analysis_*/results/
analysis_*/results_smoke/

# Per-run wall logs (machine-specific timestamps + paths)
logs/

# Internal research artifacts not for public release
JOURNAL.md
CLAUDE.md
analysis/

# In-place TSV patch backups (created by any historical judge rerun
# tooling; safe to discard once the patch is verified)
*.pre_rejudge_*
*.pre_batchjudge_*
*.before_clean_*
*.before_recover_*
*.before_30kcap_*

# Outside-archives sibling dir (anything moved here is intentionally
# excluded — should never be a subpath of the repo, but defensive)
_lcvb_outside_archives/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# IDE / OS
.DS_Store
.vscode/
.idea/
*.swp
.ipynb_checkpoints/
Thumbs.db

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
