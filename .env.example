# USVB API keys — copy this file to `.env` and fill in real values.
# The pipeline auto-loads `.env` at the repo root via openrouter_client._load_dotenv.
#
# Subject runs use whichever provider is auto-detected from the model
# slug (a slug containing `/` routes via OpenRouter; a bare slug like
# `claude-haiku-4-5-20251001` routes via the Anthropic SDK).
#
# Which keys you need:
#
#   - GEMINI_API_KEY: REQUIRED. The canonical judge model is
#     gemini-3-flash-preview, so every run — regardless of which subject
#     model you use — needs this key to score outputs.
#
#   - OPENROUTER_API_KEY: REQUIRED for any non-Anthropic subject model
#     (OpenAI, Gemini, Qwen, GPT-OSS, DeepSeek, etc. — any slug
#     containing a `/`).
#
#   - ANTHROPIC_API_KEY: OPTIONAL. Only needed for Anthropic-routed
#     subject models (claude-haiku / claude-sonnet / claude-opus).

GEMINI_API_KEY=your-gemini-key-here
OPENROUTER_API_KEY=sk-or-v1-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
